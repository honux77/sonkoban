7000 REM HELP SCREEN
7010 CLS
7020 LOCATE 7,1: PRINT "* MSX SOKOBAN V2 *"
7030 LOCATE 12,2: PRINT "BY HONUX"
7040 LOCATE 1,5: PRINT "CONTROLS"
7050 LOCATE 1,6: PRINT "ARROWS    MOVE"
7060 LOCATE 1,7: PRINT "R         RESET STAGE"
7070 LOCATE 1,8: PRINT "1-5       SELECT STAGE"
