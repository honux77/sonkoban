5090 DATA 60,126,126,60,66,36,60,36
5100 DATA 0,0,0,0,60,24,0,0
5110 DATA 0,0,0,0,0,0,0,0
5120 REM - DOWN
5130 DATA 60,66,66,60,66,36,60,36
5140 DATA 0,60,60,0,60,24,0,0
5150 DATA 0,0,0,0,0,0,0,0

5200 REM TILE PATTERNS
5205 DATA 0,0,0,0,0,0,0,0
5210 DATA 255,238,255,187,255,238,255,187
5220 DATA 126,129,129,129,129,129,129,126
5225 DATA 60,66,129,153,153,129,66,60
5230 DATA 126,129,129,129,129,129,129,126
5240 DATA 0,0,32,0,0,0,4,0
5245 REM TILE 6 - STAR PATTERN (6-POINTED ASTERISK 8X8)
5246 DATA 24,90,60,255,60,90,24,0
5250 DATA &H1B,&H98,&H3C,&H74,&HF2,&H1B,&H9B

5500 REM CHECK WIN
5505 FOR CY=0 TO H-1
5510   FOR CX=0 TO W-1
5515     IF MAP(CY,CX)=2 THEN RETURN
5520   NEXT CX
5525 NEXT CY
5530 SC=SC+1: LV=LV+1: IF LV<=MX THEN 5535
5531 GOSUB 5600: GOSUB 7200: END
5535 D=0: P=0
5536 FOR I=0 TO 11: PUT SPRITE I,(260,200),1: NEXT I
5537 GOSUB 4000: GOSUB 2000: GOSUB 5600
5538 RETURN
5600 REM DRAW STARS
5610 FOR I=0 TO SC-1: VPOKE &H1800+I,176: NEXT I
5620 RETURN

