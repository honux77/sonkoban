1 REM MSX SOKOBAN V2 BY HONUX
2 DEFINT A-Z
3 CALL TURBO ON
4 DIM MAP(12,21)

100 REM INIT
105 SCREEN 1,2: COLOR 1,11,14
110 D=0: P=0: LV=1: MX=5: SC=0: BF=0: SF=0: U=0: V=0: W=32: H=24
120 GOSUB 1000: REM LOAD SPRITES
130 GOSUB 3000: REM LOAD TILES
135 GOSUB 8000: REM INIT PSG
138 GOSUB 7000: REM HELP SCREEN
140 GOSUB 4000: REM DRAW LEVEL
145 GOSUB 2000: REM DRAW PLAYER

200 REM GAME LOOP
205 A$=INKEY$
210 IF A$="" THEN 205
215 P=D: DX=0: DY=0
220 IF A$=CHR$(28) THEN DX=1: D=0: GOTO 265
230 IF A$=CHR$(29) THEN DX=-1: D=1: GOTO 265
240 IF A$=CHR$(30) THEN DY=-1: D=2: GOTO 265
250 IF A$=CHR$(31) THEN DY=1: D=3: GOTO 265
255 IF A$=CHR$(27) THEN END
257 IF A$="R" OR A$="r" THEN GOSUB 285: GOTO 205
258 IF A$>="1" AND A$<="5" THEN LV=ASC(A$)-48: SC=LV-1: GOSUB 285: GOTO 205
260 GOTO 205
285 D=0: P=0: BF=0: SF=0: FOR I=0 TO 11: PUT SPRITE I,(260,200),1: NEXT I
286 GOSUB 4000: GOSUB 2000: GOSUB 5600: RETURN
264 SF=0
266 GOSUB 500: REM TRY MOVE
268 IF SF=1 THEN GOSUB 8100
269 IF SF=2 THEN GOSUB 8200
270 GOSUB 2000: REM DRAW SPRITES
275 IF BF=0 THEN 280
276 BF=0: GOSUB 5500
280 GOTO 205

500 REM TRY MOVE
505 NX=PX+DX: NY=PY+DY
510 TX=NX-U: TY=NY-V
515 IF TX<0 OR TY<0 OR TX>=W OR TY>=H THEN RETURN
520 T=MAP(TY,TX)
525 IF T=0 OR T=1 THEN RETURN
530 IF T<>2 AND T<>4 THEN PX=NX: PY=NY: SF=1: RETURN
535 REM BOX PUSH
540 BX=TX+DX: BY=TY+DY
545 IF BX<0 OR BY<0 OR BX>=W OR BY>=H THEN RETURN
550 BT=MAP(BY,BX)
555 IF BT=0 OR BT=1 OR BT=2 OR BT=4 THEN RETURN
560 IF MAP(TY,TX)=4 THEN MAP(TY,TX)=3 ELSE MAP(TY,TX)=5
565 IF BT=3 THEN MAP(BY,BX)=4 ELSE MAP(BY,BX)=2
570 VPOKE &H1800+U+TX+(TY+V)*32,MAP(TY,TX)*8+128
575 VPOKE &H1800+U+BX+(BY+V)*32,MAP(BY,BX)*8+128
576 SF=2
577 BF=1
580 PX=NX: PY=NY
590 RETURN

1000 REM LOAD SPRITES
1010 FOR I=0 TO 11
1020   S$=""
1030   FOR J=0 TO 7: READ A: S$=S$+CHR$(A): NEXT J
1040   SPRITE$(I)=S$
1050 NEXT I
1060 RETURN

2000 REM DRAW SPRITES
2005 IF P<>D THEN GOSUB 2100
2006 N=D*3: SX=PX*8-1: SY=PY*8-1
2010 PUT SPRITE N,(SX,SY),1
2020 PUT SPRITE N+1,(SX,SY),15
2030 PUT SPRITE N+2,(SX,SY),10
2040 RETURN
2100 REM ERASE OLD DIR SPRITES
2110 N=P*3
2120 PUT SPRITE N,(260,200),1
2130 PUT SPRITE N+1,(260,200),15
2140 PUT SPRITE N+2,(260,200),10
2150 RETURN


3000 REM LOAD TILES
3010 FOR I=0 TO 6
3015   FOR J=0 TO 7: READ R: VPOKE 1024+I*64+J,R: NEXT J
3020 NEXT I
3030 FOR I=0 TO 6: READ R: VPOKE &H2010+I,R: NEXT I
3040 RETURN

4000 REM DRAW LEVEL
4001 FOR Y=V TO V+H-1: A=&H1800+Y*32+U: FOR X=0 TO W-1: VPOKE A+X,128: NEXT X: NEXT Y
4003 ON LV GOSUB 4160,4161,4162,4163,4164
4010 READ W,H
4030 FOR Y=0 TO H-1
4040   FOR X=0 TO W-1
4050     READ R
4055     IF R=6 THEN PX=X: PY=Y: R=5
4060     MAP(Y,X)=R
4070   NEXT X
4080 NEXT Y
4090 U=16-W\2: V=12-H\2
4095 PX=PX+U: PY=PY+V
4100 FOR Y=0 TO H-1: A=&H1800+(Y+V)*32+U
4110   FOR X=0 TO W-1: VPOKE A+X,MAP(Y,X)*8+128: NEXT X
4120 NEXT Y
4150 RETURN
4160 RESTORE 6000: RETURN
4161 RESTORE 6200: RETURN
4162 RESTORE 6400: RETURN
4163 RESTORE 6600: RETURN
4164 RESTORE 6800: RETURN

5000 REM SPRITE DATA - RIGHT
5010 DATA 60,66,66,60,66,37,60,36
5020 DATA 0,60,60,0,60,26,0,0
5030 DATA 0,0,0,0,0,0,0,0
5040 REM - LEFT
5050 DATA 60,66,66,60,66,164,60,36
5060 DATA 0,60,60,0,60,88,0,0
5070 DATA 0,0,0,0,0,0,0,0
