10 COLOR 1,11,14: SCREEN 1
20 DIM PL$(4,3): DIM CL(4,3)
30 GOSUB 100: REM LOAD SPRITES
40 GOSUB 200: REM DRAW SPRITES
90 PRINT "PRESS ANY KEY TO EXIT"
91 A$=INPUT$(1)
92 END

100 REM LOAD SPRITES
105 PRINT "LOADING SPRITES..."
110 FOR I= 0 TO 3
115 FOR J = 0 TO 2
120 PL$(I,J)=""
130 FOR K = 0 TO 7: READ A: PL$(I,J)=PL$(I,J)+CHR$(A): NEXT K
140 SPRITE$(I * 4 + J)=PL$(I,J)
145 PRINT "LOADING SPRITE ";I;J"... OK"
147 NEXT J
150 NEXT I
155 FOR I = 0 TO 3
156 FOR J = 0 TO 2
157 READ A: CL(I, J)=A
158 NEXT J
159 NEXT I
160 PRINT "ALL SPRITES LOADED... OK"
170 RETURN

200 REM DRAW SPRITES
205 CLS
210 X=128: Y=86
220 FOR I= 0 TO 3
230 FOR J = 0 TO 2
240 PUT SPRITE (I * 4 + J), (X,Y + 10 * I), CL(I,J), (I * 4 + J)
250 NEXT J
260 NEXT I
270 RETURN

